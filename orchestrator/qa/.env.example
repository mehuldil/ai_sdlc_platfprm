# QA Orchestrator Configuration

# ============================================================================
# REQUIRED: Anthropic Claude API
# ============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================================================
# REQUIRED: Azure DevOps Integration
# ============================================================================
ADO_ORG=your-ado-org
ADO_PROJECT=YourAzureProject
ADO_PAT=your-ado-personal-access-token-here

# ============================================================================
# OPTIONAL: Redis Configuration
# ============================================================================
# Default: localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-redis-password-here (if auth required)

# ============================================================================
# OPTIONAL: API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ============================================================================
# OPTIONAL: Claude AI Configuration
# ============================================================================
# Model to use (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL: Knowledge Base Configuration
# ============================================================================
# KB time-to-live in Redis (hours)
KB_TTL_HOURS=24

# Archive directory for KB dumps
KB_ARCHIVE_DIR=data/kb_archive

# Enable unified semantic long-term memory mirror (all orchestrators)
ENABLE_UNIFIED_SEMANTIC_MEMORY=true

# Shared semantic memory SQLite file path
SEMANTIC_MEMORY_DB_PATH=.sdlc/memory/semantic-memory.sqlite3

# ============================================================================
# OPTIONAL: Governance Configuration
# ============================================================================
# Timeout for governance gate decisions (hours)
GOVERNANCE_TIMEOUT_HOURS=24

# Auto-approve gates after timeout (true/false)
AUTO_APPROVE=false

# ============================================================================
# OPTIONAL: Test Environment Configuration
# ============================================================================
# Android device ID (from 'adb devices')
# TEST_DEVICE_ID=emulator-5554

# Path to APK to test
# TEST_APK_PATH=/path/to/app.apk

# Appium server URL
APPIUM_SERVER_URL=http://localhost:4723

# ============================================================================
# OPTIONAL: Feature Flags
# ============================================================================
# Enable webhook notifications for gate pauses
ENABLE_WEBHOOK_NOTIFICATIONS=true

# Enable metrics collection (token usage, agent duration)
ENABLE_METRICS_COLLECTION=true

# Enable parallel execution of independent agents (experimental)
ENABLE_PARALLEL_EXECUTION=false

# Enable REFINE option for all governance gates
ENABLE_REFINE_GATES=true
