# Copy values into ai-sdlc-platform/env/.env (or export before `sdlc ado create feature`).
# Feature work items in your Azure DevOps project require these fields plus a valid org identity for Assigned To.
#
# ADO_USER_EMAIL must be an email that exists in your Azure DevOps organization directory
# (personal Gmail often fails with "unknown identity").

# ADO_FEATURE_ANALYTICS_FUNNEL — must match process picklist (your process template uses e.g. "Yes"; not "Onboarding")
ADO_FEATURE_ANALYTICS_FUNNEL=Yes

# ADO_FEATURE_FIREBASE_CONFIG_REQUIRED=<Yes or No per process allowed values>
ADO_FEATURE_FIREBASE_CONFIG_REQUIRED=Yes

# ADO_FEATURE_SUCCESS_CRITERIA=<short text — e.g. PRD KPIs + binary onboarding definition>
ADO_FEATURE_SUCCESS_CRITERIA=PRD v1.0: onboarding complete when OTP + language + one permission screen + one key action; KPIs per PRD section 3.

# Optional override (defaults to ADO_WI_PLATFORM_example-org)
# ADO_FEATURE_PLATFORM_example-org=Android;Database;Devops;Server;Web
