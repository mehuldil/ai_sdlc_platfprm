# ============================================================================
# AI-SDLC Platform Environment Configuration Template
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env (in the same directory)
# 2. Fill in all values marked as REQUIRED
# 3. Keep .env out of version control (add to .gitignore)
# 4. Never commit .env to git
# 5. Run 'sdlc doctor' to validate configuration
#
# SECURITY:
# - This is a public template with NO real secrets
# - Replace all placeholder values with actual credentials
# - Store .env securely (restrictive file permissions: 0600)
# - Use different credentials for dev/staging/production
#
# ============================================================================

# ══════════════════════════════════════════════════════════════════════════
# PROJECT CONFIGURATION (Required)
# ══════════════════════════════════════════════════════════════════════════

# Project name — used for logging, naming artifacts
# Example: "cloud-platform", "mobile-app", "data-pipeline"
PROJECT_NAME=my-project

# Project root directory (absolute path or relative to working directory)
# Example: "." or "/home/user/projects/my-project"
PROJECT_ROOT=.

# Organization name
# Example: "your-ado-org", "YourAzureProject"
ORG_NAME=your-ado-org

# Azure DevOps Project name (for work item tracking)
# Example: "YourAzureProject"
ADO_PROJECT=YourAzureProject

# SDLC Platform root directory (set during setup)
# Example: "/home/user/.local/share/ai-sdlc-platform"
SDLC_PLATFORM_ROOT=

# Auto-sync shared memory to git (true/false)
# When true: memory files are auto-committed to .sdlc/memory/
# When false: manual git push required
SDLC_MEMORY_AUTO_SYNC=true

# ══════════════════════════════════════════════════════════════════════════
# AZURE DEVOPS CONFIGURATION (Required for MCP + ADO integration)
# ══════════════════════════════════════════════════════════════════════════

# Azure DevOps Organization name
# Found at: https://dev.azure.com/[ORG_NAME]
# Example: "your-ado-org"
ADO_ORG=your-ado-org

# Azure DevOps Project GUID (36-character UUID)
# Found at: https://dev.azure.com/[ORG]/[PROJECT]/_settings/project-details
# Example: "12345678-abcd-efgh-ijkl-1234567890ab"
ADO_PROJECT_ID=

# Azure DevOps user display name (for commit attribution, agent identity)
# Used in: git commits, agent signatures, logging
# Example: "John Doe", "Jane Smith"
ADO_USER_NAME=

# Azure DevOps user email (login email)
# Used by: MCP authentication, git config user.email
# Example: "john.doe@example.com"
ADO_USER_EMAIL=

# Azure DevOps user GUID (36-character UUID)
# Found at: Profile > User Settings (look for "ID" field)
# Example: "87654321-efgh-ijkl-abcd-0987654321fe"
ADO_USER_ID=

# Azure DevOps Personal Access Token (PAT) — 60+ character token
# CRITICAL: Never commit this value
# Create at: https://dev.azure.com/[ORG]/_usersSettings/tokens
# Required scopes:
#   - Work Items (Read & Write)
#   - Code (Read & Write)
#   - Release (Read)
#   - Build (Read)
# Used by: validate-config.sh, MCP server (env/mcp-start.sh)
# WARNING: Once created, cannot be recovered. Store securely.
# Example: "abcdefghijklmnopqrstuvwxyz1234567890abcdefghijkl"
ADO_PAT=

# ══════════════════════════════════════════════════════════════════════════
# WIKI.JS CONFIGURATION (Optional — for knowledge base integration)
# ══════════════════════════════════════════════════════════════════════════

# Wiki.js API Token (for MCP server wikijs)
# Create at: Your Wiki.js instance > Profile > API Access Tokens
# Format: Bearer token (alphanumeric, 30+ characters)
# Example: "abcdefghijklmnopqrstuvwxyz1234567890"
WIKIJS_TOKEN=

# Alternative wiki token (legacy, if WIKIJS_TOKEN is not set)
# Mapped to WIKIJS_API_KEY in env/mcp-start.sh
WIKI_TOKEN=

# ══════════════════════════════════════════════════════════════════════════
# ELASTICSEARCH CONFIGURATION (Optional — for log indexing/search)
# ══════════════════════════════════════════════════════════════════════════

# Elasticsearch URL (full URL with protocol and port)
# Example: "https://elasticsearch.example.com:9200"
# Leave empty to disable Elasticsearch integration
ES_URL=

# Elasticsearch username (for basic auth)
# Example: "elastic"
ES_USER=

# Elasticsearch password (for basic auth)
# CRITICAL: Never commit this value
# Example: "abc123xyz789abc123xyz789"
ES_PWD=

# ══════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE & SERVICES (Optional)
# ══════════════════════════════════════════════════════════════════════════

# Redis connection URL (for caching, session storage, token tracking)
# Format: redis://[user]:[password]@[host]:[port]/[database]
# Example (local dev): "redis://localhost:6379"
# Example (cloud): "redis://user:pass@redis.example.com:6379/0"
# Leave empty to disable Redis caching
REDIS_URL=redis://localhost:6379

# OpenAI API Key (optional; Claude is default LLM)
# Create at: https://platform.openai.com/account/api-keys
# Used for: supplementary LLM requests (if configured)
# CRITICAL: Never commit this value
# Example: "sk-abc123xyz789abc123xyz789abc123"
OPENAI_KEY=

# ══════════════════════════════════════════════════════════════════════════
# LOGGING & MONITORING
# ══════════════════════════════════════════════════════════════════════════

# Log level (DEBUG, INFO, WARN, ERROR)
# DEBUG: verbose output for troubleshooting
# INFO: normal operation
# WARN: warnings and errors
# ERROR: errors only
LOG_LEVEL=INFO

# Token usage log file (relative to project root or absolute path)
# Tracks API token consumption for billing and quota enforcement
# Example: "env/.token-usage.log"
TOKEN_LOG_FILE=env/.token-usage.log

# ══════════════════════════════════════════════════════════════════════════
# ADVANCED CONFIGURATION (Optional — defaults provided)
# ══════════════════════════════════════════════════════════════════════════

# API request timeout (in seconds)
API_TIMEOUT=30

# Retry policy (max attempts for failed requests)
API_RETRY_MAX=3

# Rate limiting (requests per minute)
API_RATE_LIMIT=60

# ══════════════════════════════════════════════════════════════════════════
# VALIDATION
# ══════════════════════════════════════════════════════════════════════════
#
# To validate this configuration:
#   1. Copy to .env
#   2. Fill in all REQUIRED fields
#   3. Run: ./scripts/validate-config.sh
#   4. Run: ./scripts/doctor.sh
#
# Required fields (must not be empty):
#   - ADO_ORG
#   - ADO_PROJECT
#   - ADO_PROJECT_ID
#   - ADO_USER_NAME
#   - ADO_USER_EMAIL
#   - ADO_USER_ID
#   - ADO_PAT
#
# ══════════════════════════════════════════════════════════════════════════
