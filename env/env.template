# AI SDLC Platform Environment Configuration
# Copy this file to .env and fill in your values
# CRITICAL: Never commit .env to version control

# ============================================================================
# AZURE DEVOPS CONFIGURATION (Required)
# ============================================================================

# Azure DevOps Organization name
# Example: "your-ado-org"
ADO_ORG=your-ado-org

# Azure DevOps Project name
# Example: "YourAzureProject"
ADO_PROJECT=YourAzureProject

# Azure DevOps Project GUID (36-char UUID)
# Found at: https://dev.azure.com/ORG/PROJECT/_settings/project-details
# Example: "12345678-abcd-efgh-ijkl-1234567890ab"
ADO_PROJECT_ID=

# Display name (ADO profile) — used by agents / MCP identity
ADO_USER_NAME=

# Your Azure DevOps user email (login email)
# Example: "user@example.com"
ADO_USER_EMAIL=

# ADO user GUID — User Settings > Profile (same as ai-claude-platform)
ADO_USER_ID=

# Optional: full org URL (documentation / links)
# ADO_ORG_URL=https://dev.azure.com/your-ado-org

# Azure DevOps Personal Access Token (60-char)
# Create at: https://dev.azure.com/[ORG]/_usersSettings/tokens
# Scopes required: Work Items (Read & Write), Code (Read & Write), Release (Read)
# Used by: validate-config.sh, MCP (env/mcp-start.sh → @azure-devops/mcp as ADO_MCP_AUTH_TOKEN)
# WARNING: Store securely; cannot be recovered once created
ADO_PAT=

# Optional — defaults applied by `sdlc ado create story` when project rules require Custom.* fields:
# ADO_WI_DEPENDENCY=Android;Server;Web
# ADO_WI_USERSTORY_SOURCE=Product Backlog
# ADO_WI_PLATFORM_JIOCLOUD=Android;Database;Devops;Server;Web

# ============================================================================
# WIKI.JS (Optional — MCP server wikijs in mcp.json)
# ============================================================================
# Wiki URL is set in mcp.json (default: https://wiki.jcinternal.com). Override there if needed.
# Token: Profile > API Access Tokens on your Wiki.js host
WIKIJS_TOKEN=

# Legacy alias — still mapped to WIKIJS_API_KEY in env/mcp-start.sh (if WIKIJS_TOKEN unset)
WIKI_TOKEN=

# ============================================================================
# ELASTICSEARCH (Optional — MCP server elasticsearch in mcp.json)
# ============================================================================
ES_URL=
ES_USER=
ES_PWD=

# ============================================================================
# INFRASTRUCTURE (Optional)
# ============================================================================

# Redis cache connection URL (for token tracking, session storage)
# Format: redis://[user]:[password]@[host]:[port]/[database]
# Example: "redis://localhost:6379" (local development)
# Leave empty to disable caching
REDIS_URL=redis://localhost:6379

# OpenAI API Key (optional; Claude is default LLM)
# Format: sk-[rest of key]
# Leave empty to use Claude (Anthropic) by default
OPENAI_KEY=

# ============================================================================
# LOGGING & MONITORING (Optional)
# ============================================================================

# Log level: DEBUG | INFO | WARN | ERROR
# Default: INFO
LOG_LEVEL=INFO

# Token usage log file path (tracks daily/sprint budgets)
# Default: env/.token-usage.log
TOKEN_LOG_FILE=env/.token-usage.log

# ============================================================================
# VALIDATION
# ============================================================================
# Run './scripts/validate-config.sh' after filling this file
# All ADO_* fields are required
# All other fields optional (check tool documentation)
