# Token-optimized environment template (v2.1.2)
#
# Drop this into your repo as env/.env (or source it from ~/.sdlc/ado.env).
# Each variable is documented — uncomment what you want active.
#
# Full playbook: rules/token-optimization.md → "Further Reductions (v2.1.2)"

# ──────────────────────────────────────────────────────────────────────────────
# BUDGET DISCIPLINE (v2.1.2)
# ──────────────────────────────────────────────────────────────────────────────

# Scale all role + stage budgets. Default 1.0 (no change).
#   0.8 = 20% tighter (recommended for teams optimizing spend)
#   1.0 = platform defaults
#   1.2 = 20% looser (emergency override — document in ADO)
# SDL_TOKEN_BUDGET_MULTIPLIER=0.8

# ──────────────────────────────────────────────────────────────────────────────
# MODULE LOAD CACHE (v2.1.2)
# ──────────────────────────────────────────────────────────────────────────────

# Smart-load cache TTL in seconds. Default 3600 (1 hour).
#   86400  = 24h — use for single-day focused sprint on one module
#   3600   = default, recommended for multi-module branch work
#   0      = disable cache (never use — wastes tokens re-scanning)
# SDL_MODULE_CACHE_TTL=86400

# ──────────────────────────────────────────────────────────────────────────────
# STAGE RE-RUN (v2.1.2)
# ──────────────────────────────────────────────────────────────────────────────

# Suppress the "stage already completed" warning. Default 0.
# Only set to 1 when deliberately re-running (e.g., requirements changed).
# SDL_FORCE_RERUN=0

# ──────────────────────────────────────────────────────────────────────────────
# MODEL OVERRIDE (uses rules/model-selection.md defaults unless set)
# ──────────────────────────────────────────────────────────────────────────────

# Force a specific model for all stages this session. Leave unset to use
# per-stage defaults (haiku for 01-04/07/12-15, sonnet for 08-11, opus for 05).
# SDL_MODEL=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────────────────────────
# MODULE INIT (bulk setup only)
# ──────────────────────────────────────────────────────────────────────────────

# Skip `sdlc module init` during ./setup.sh. Set for bulk manifest runs only.
# Remember to run `sdlc module init .` per repo afterward where needed.
# SDL_SKIP_MODULE_INIT=1

# ──────────────────────────────────────────────────────────────────────────────
# DOC-INGESTION LIBRARIES (bulk setup only)
# ──────────────────────────────────────────────────────────────────────────────

# Skip python doc-ingestion libs install. Faster bulk setup; some `sdlc doc` paths disabled.
# SDL_SKIP_DOC_LIBS=1

# ──────────────────────────────────────────────────────────────────────────────
# ADO (loaded from ~/.sdlc/ado.env first — keep secrets there, not here)
# ──────────────────────────────────────────────────────────────────────────────
# ADO_ORG=
# ADO_PROJECT=
# ADO_PAT=
