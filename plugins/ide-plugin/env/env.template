# Azure DevOps Configuration
# Copy this file to env/.env and fill in your values

# Azure DevOps Organization (e.g., "your-ado-org")
ADO_ORG=your-ado-org

# Azure DevOps Project (e.g., "YourAzureProject")
ADO_PROJECT=YourAzureProject

# Azure DevOps Personal Access Token (get from https://dev.azure.com > User Settings > Personal access tokens)
# IMPORTANT: Keep this secret. Never commit to version control.
# Scopes required: Work Items (Read & Write), Code (Read)
ADO_PAT=

# Optional: Default model for skill execution (haiku, sonnet, opus)
# Default: sonnet
# Use haiku for simple tasks (faster, cheaper)
# Use opus for complex architecture decisions (more powerful)
MODEL_TIER=sonnet

# Optional: Path to .sdlc/memory directory for context persistence
# Default: .sdlc/memory
MEMORY_PATH=.sdlc/memory

# Optional: Default canary rollout percentage for deployments
# Default: 5 (5% of traffic)
# Reduce for risky features, increase for safe changes
CANARY_PERCENTAGE=5

# Optional: Logging level (debug, info, warn, error)
# Default: info
LOG_LEVEL=info

# Optional: Enable debug mode (very verbose output)
DEBUG=false
